# Use official PyTorch image with CUDA 12.4 support
FROM pytorch/pytorch:2.6.0-cuda12.4-cudnn9-runtime

# Set working directory
WORKDIR /app

# Install system dependencies for OpenCV
RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copy project files
COPY pyproject.toml .
COPY main.py .

# Install uv
RUN pip install uv

# Install dependencies (excluding torch/torchvision, already in base image)
RUN uv pip install --system \
    numpy>=1.26.0 \
    opencv-python>=4.13.0.92 \
    supervision>=0.28.0 \
    ultralytics>=8.4.51

# Copy the rest of your files (model, video, mask)
COPY . .

# Run the script
CMD ["python", "main.py"]